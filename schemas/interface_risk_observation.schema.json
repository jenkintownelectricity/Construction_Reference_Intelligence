{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Interface Risk Observation",
  "description": "Risk observation at a building envelope interface zone.",
  "type": "object",
  "required": ["schema_version", "observation_id", "interface_zone", "risk_category", "severity", "confidence"],
  "properties": {
    "schema_version": { "type": "string", "const": "v1" },
    "observation_id": { "type": "string" },
    "interface_zone": { "type": "string", "enum": ["roof_to_wall", "parapet_transition", "penetration", "fenestration_edge", "below_grade_transition", "expansion_joint", "deck_to_wall", "roof_edge", "curb_transition", "drain_transition"] },
    "risk_category": { "type": "string" },
    "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
    "confidence": { "type": "string", "enum": ["low", "medium", "high", "established"] },
    "control_layers_affected": {
      "type": "array",
      "items": { "type": "string", "enum": ["bulk_water_control", "capillary_control", "air_control", "vapor_control", "thermal_control", "fire_smoke_control", "movement_control", "weathering_surface", "drainage_plane", "protection_layer", "vegetation_support_layer"] }
    },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "mitigation_refs": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
