{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Data Gap Record",
  "description": "Identifies a gap in available intelligence data.",
  "type": "object",
  "required": ["schema_version", "gap_id", "title", "domain", "severity", "status"],
  "properties": {
    "schema_version": { "type": "string", "const": "v1" },
    "gap_id": { "type": "string" },
    "title": { "type": "string" },
    "domain": { "type": "string" },
    "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
    "status": { "type": "string", "enum": ["open", "addressed", "deferred"] },
    "description": { "type": "string" },
    "needed_evidence_types": {
      "type": "array",
      "items": { "type": "string", "enum": ["field_observation", "lab_test", "forensic_report", "manufacturer_data", "literature", "expert_judgment", "sensor_data", "inspection_report", "commissioning_report", "warranty_claim"] }
    },
    "related_kernel_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kernel", "entry_id"],
        "properties": { "kernel": { "type": "string" }, "entry_id": { "type": "string" } },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
