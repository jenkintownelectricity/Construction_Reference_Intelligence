{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Precedent Record",
  "description": "Historical case record for construction precedents.",
  "type": "object",
  "required": ["schema_version", "precedent_id", "title", "status", "confidence"],
  "properties": {
    "schema_version": { "type": "string", "const": "v1" },
    "precedent_id": { "type": "string" },
    "title": { "type": "string" },
    "status": { "type": "string", "enum": ["active", "draft", "deprecated", "superseded"] },
    "confidence": { "type": "string", "enum": ["low", "medium", "high", "established"] },
    "case_date": { "type": "string", "format": "date" },
    "location": { "type": "string" },
    "description": { "type": "string" },
    "outcome": { "type": "string" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "kernel_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kernel", "entry_id"],
        "properties": { "kernel": { "type": "string" }, "entry_id": { "type": "string" } },
        "additionalProperties": false
      }
    },
    "lessons": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
