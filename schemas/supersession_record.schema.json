{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Supersession Record",
  "description": "Records the supersession chain when one record replaces another.",
  "type": "object",
  "required": ["schema_version", "supersession_id", "superseded_record_id", "superseding_record_id", "reason", "effective_date"],
  "properties": {
    "schema_version": { "type": "string", "const": "v1" },
    "supersession_id": { "type": "string" },
    "superseded_record_id": { "type": "string" },
    "superseding_record_id": { "type": "string" },
    "reason": { "type": "string" },
    "effective_date": { "type": "string", "format": "date" }
  },
  "additionalProperties": false
}
